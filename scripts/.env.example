# Source: Supabase project "nrighar" (ref gtadgowykacetxpykgru)
# Direct Postgres connection string (Dashboard -> Project Settings -> Database ->
# Connection string -> URI, use the non-pooled/direct one, not the pgbouncer port).
SUPABASE_DB_URL=postgresql://postgres:<password>@db.gtadgowykacetxpykgru.supabase.co:5432/postgres

# Project URL + service role key (Dashboard -> Project Settings -> API).
# Service role is needed to list/download every object in the private
# "documents" Storage bucket regardless of owner.
SUPABASE_URL=https://gtadgowykacetxpykgru.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service role key>

# Destination: the new Postgres on Hetzner/Coolify.
# Use the resource's PUBLIC connection info for running this script from your
# laptop (Coolify can expose a temporary public port for the DB resource, or
# SSH-tunnel: ssh -L 5433:nrighar-postgres:5432 root@<server-public-ip>, then
# point this at localhost:5433). Never leave the DB publicly exposed long-term
# — see infra/README.md.
NEW_DATABASE_URL=postgresql://postgres:<password>@localhost:5433/postgres

# Cloudflare R2 (see infra/r2-setup.md)
R2_ACCOUNT_ID=<account id>
R2_ACCESS_KEY_ID=<access key id>
R2_SECRET_ACCESS_KEY=<secret access key>
R2_BUCKET=nrighar-documents
