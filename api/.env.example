# Postgres connection (Coolify-managed Postgres in prod; local docker-compose.dev.yml in dev)
DATABASE_URL=postgres://nrighar:nrighar@localhost:5432/nrighar

# HTTP server
PORT=8080

# JWT access-token signing secret. Generate with: openssl rand -hex 32
JWT_SECRET=changeme

# Comma-separated list of allowed CORS origins (web app + local dev)
CORS_ORIGINS=http://localhost:3000,https://nrighar.3pandalabs.com

# Cloudflare R2 (S3-compatible). Bucket must be created ahead of time; see infra/README.md
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=nrighar-documents
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# KYC document verification (only read by the Temporal worker process — see
# src/temporal/activities/kyc.ts). Without it, kyc-typed document uploads
# still get a kyc_verifications row, just with status "failed" and no
# extraction. Vision-capable Claude model; the default is a good tradeoff of
# quality vs cost for reading scanned ID documents.
ANTHROPIC_API_KEY=
ANTHROPIC_KYC_MODEL=claude-sonnet-5

# Official PAN/Aadhaar/passport verification providers are NOT wired up yet
# (see src/lib/kyc/officialVerify.ts) — every document currently lands in
# manual_review after extraction rather than auto-verified, pending a real
# licensed KYC-API provider integration.
