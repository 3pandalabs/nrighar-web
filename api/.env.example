# Postgres connection (Coolify-managed Postgres in prod; local docker-compose.dev.yml in dev)
DATABASE_URL=postgres://nrighar:nrighar@localhost:5432/nrighar

# HTTP server
PORT=8080

# JWT access-token signing secret. Generate with: openssl rand -hex 32
JWT_SECRET=changeme

# Comma-separated list of allowed CORS origins (web app + local dev)
CORS_ORIGINS=http://localhost:3000,https://nrighar.3pandalabs.com

# Cloudflare R2 (S3-compatible). Bucket must be created ahead of time; see infra/README.md
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=nrighar-documents
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
